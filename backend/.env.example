# ============================================================
# u-bike Backend — Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:9002

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────
# Supabase
# Get from: https://app.supabase.com → Project Settings → API
# ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ─────────────────────────────────────────
# Redis (Upstash — https://upstash.com)
# ─────────────────────────────────────────
REDIS_URL=redis://default:your_token@your-instance.upstash.io:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────
# Paystack (https://paystack.com)
# Dashboard → Settings → API Keys & Webhooks
# ─────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
PAYSTACK_BASE_URL=https://api.paystack.co

# ─────────────────────────────────────────
# Africa's Talking (https://africastalking.com)
# Dashboard → Settings → API Key
# ─────────────────────────────────────────
AFRICASTALKING_API_KEY=your_africastalking_api_key
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_SENDER_ID=UBIKE
AFRICASTALKING_ENV=sandbox
# Set AFRICASTALKING_ENV=production for live

# ─────────────────────────────────────────
# Mapbox (https://mapbox.com)
# Account → Tokens → Create a token
# ─────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_access_token
MAPBOX_BASE_URL=https://api.mapbox.com

# NOTE: Firebase / FCM is NOT used. Push notifications use:
#   - Socket.IO (connected users)
#   - Supabase Realtime (DB subscriptions on mobile)
#   - Africa's Talking SMS (offline/critical alerts)

# ─────────────────────────────────────────
# Agora (in-app voice calls — https://agora.io)
# Console → Project Management → Create a project
# ─────────────────────────────────────────
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# ─────────────────────────────────────────
# OTP Settings
# ─────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# ─────────────────────────────────────────
# Platform Business Logic
# ─────────────────────────────────────────
# Commission rates (as decimals)
PLATFORM_COMMISSION_STANDARD=0.20
PLATFORM_COMMISSION_ADJUSTED=0.25
# Ride pricing (KES)
BASE_FARE_KES=100
KM_RATE_KES=50
ELECTRIC_SURCHARGE_MULTIPLIER=1.2
ERRAND_BASE_FARE_KES=150
# Rider matching radius (km)
RIDER_MATCH_RADIUS_KM=5
RIDER_REQUEST_TIMEOUT_SECONDS=30

# ─────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─────────────────────────────────────────
# Encryption
# ─────────────────────────────────────────
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_32_byte_encryption_key_here
