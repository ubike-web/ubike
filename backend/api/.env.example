# ============================================================
# u-bike API — Environment Variables
# Copy to .env and fill in your values
# ============================================================

NODE_ENV=production
PORT=3001
FRONTEND_URL=https://ubike-admin.vercel.app

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Supabase
SUPABASE_URL=https://wkqbbovazwphkeeurinz.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (Upstash)
REDIS_URL=rediss://...

# Paystack
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_BASE_URL=https://api.paystack.co

# Africa's Talking
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=UBIKE

# OpenRouteService (Maps)
ORS_API_KEY=

# ZEGOCLOUD
ZEGO_APP_ID=
ZEGO_SERVER_SECRET=

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# Business Logic
PLATFORM_COMMISSION_STANDARD=0.20
PLATFORM_COMMISSION_ADJUSTED=0.25
BASE_FARE_KES=100
KM_RATE_KES=50
ERRAND_BASE_FARE_KES=150
RIDER_MATCH_RADIUS_KM=5
RIDER_REQUEST_TIMEOUT_SECONDS=30
MAX_FARE_RAISE_PERCENT=30

# Rate Limiting
THROTTLE_WINDOW_MS=60000
THROTTLE_MAX=100

# Encryption
ENCRYPTION_KEY=
