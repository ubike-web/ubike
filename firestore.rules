rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * U-BIKE SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset enforces a dual-role ownership and shared-access model. It distinguishes between 
     * 'Users' (passengers/customers) and 'Riders' (service providers). Access is strictly controlled 
     * through UID verification against document paths and internal denormalized fields.
     *
     * Data Structure:
     * - /user_profiles/{userId}: Private user data.
     * - /rider_profiles/{riderId}: Publicly viewable rider information, owner-managed.
     * - /ride_requests & /errand_requests: Shared transactional data between a user and a rider.
     * - /rider_wallets/{riderId}: Private financial data for riders.
     *
     * Key Security Decisions:
     * 1. Authorization Independence: We rely on denormalized 'userId' and 'riderId' fields within 
     *    transactional documents (rides, errands, payments) to avoid expensive cross-document lookups.
     * 2. Public Rider Discovery: Rider profiles are readable by any authenticated user to facilitate 
     *    the booking process and "Favorite Rider" functionality.
     * 3. Relational Integrity: On creation, we enforce that the 'userId' field in requests 
     *    matches the authenticated requester's UID.
     * 4. Prototyping Flexibility: Rules do not enforce strict data types or schemas for non-security 
     *    fields, allowing for rapid iteration of the "Errands" and "Weather" features.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches a provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user's UID matches the ID of an existing document. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user is a participant (user or rider) in a shared document. */
    function isParticipant(data) {
      return isSignedIn() && (request.auth.uid == data.userId || request.auth.uid == data.riderId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Private user profile management.
     * @path /user_profiles/{userId}
     * @allow (get, create) userId matches auth.uid.
     * @deny Any access if auth.uid does not match path userId.
     * @principle Path-based ownership.
     */
    match /user_profiles/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rider profiles are readable by all users for booking, but only editable by the rider.
     * @path /rider_profiles/{riderId}
     * @allow (get) Any signed-in user to view rider cards.
     * @deny (write) Any user who is not the specific rider.
     * @principle Public Read with Owner-Only Writes.
     */
    match /rider_profiles/{riderId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(riderId) && request.resource.data.id == riderId;
      allow update: if isExistingOwner(riderId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(riderId);
    }

    /**
     * @description Ride requests shared between a user and an assigned rider.
     * @path /ride_requests/{rideRequestId}
     * @allow (create) Authenticated user setting themselves as the userId.
     * @allow (read, update) The specific user or assigned rider.
     * @principle Shared access via denormalized UIDs.
     */
    match /ride_requests/{rideRequestId} {
      allow get, list: if isParticipant(resource.data);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if resource != null && (isParticipant(resource.data) || isParticipant(request.resource.data));
      allow delete: if resource != null && request.auth.uid == resource.data.userId;
    }

    /**
     * @description Errand requests shared between a user and an assigned rider.
     * @path /errand_requests/{errandRequestId}
     * @allow (create) User initiating an errand.
     * @allow (read, update) User or rider assigned to the errand.
     * @principle Shared access via denormalized UIDs.
     */
    match /errand_requests/{errandRequestId} {
      allow get, list: if isParticipant(resource.data);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if resource != null && (isParticipant(resource.data) || isParticipant(request.resource.data));
      allow delete: if resource != null && request.auth.uid == resource.data.userId;
    }

    /**
     * @description Financial transactions viewable by the payer (user) and receiver (rider).
     * @path /payment_transactions/{transactionId}
     * @allow (get, list) Participation in the transaction.
     * @deny (update, delete) Financial records are immutable.
     * @principle Shared Read-Only Access.
     */
    match /payment_transactions/{transactionId} {
      allow get, list: if isParticipant(resource.data);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    /**
     * @description Feedback left by users for riders.
     * @path /ride_feedback/{feedbackId}
     * @allow (create) User who participated in the ride.
     * @allow (read) Both the author and the recipient rider.
     * @principle Shared access via denormalized UIDs.
     */
    match /ride_feedback/{feedbackId} {
      allow get, list: if isParticipant(resource.data);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId);
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Private financial wallets belonging to riders.
     * @path /rider_wallets/{riderId}
     * @allow (read) The specific rider.
     * @deny (write) Direct client-side writes are restricted; typically updated via server/triggers.
     * @principle Owner-only read access for sensitive data.
     */
    match /rider_wallets/{riderId} {
      allow get, list: if isOwner(riderId);
      // Wallet balance changes should typically happen via Cloud Functions after payment, 
      // but we allow creation for the rider profile setup.
      allow create: if isOwner(riderId);
      allow update, delete: if false; // Secure against direct client modification
    }
  }
}